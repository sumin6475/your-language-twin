{
  "$meta": {
    "name": "Your Ideal Role Model — Design Tokens",
    "version": "1.0.0",
    "direction": "Signature Blue (crafted-modern, blue as accent only, soft depth, not warm-paper)",
    "frozen": "2026-07-18",
    "source": "design-system-workflow.md, Steps 1-3 + audit"
  },

  "color": {
    "background": {
      "base":    { "value": "#FFFFFF", "use": "page background" },
      "subtle":  { "value": "#FAFAFB", "use": "section dividers, card fill on white" }
    },
    "text": {
      "primary":   { "value": "#18181B", "use": "headlines, body" },
      "secondary": { "value": "#52525B", "use": "supporting body, the 'why' text" },
      "tertiary":  { "value": "#71717A", "use": "roles, timestamps, meta labels — the floor for readable grey" }
    },
    "blue": {
      "deep":   { "value": "#1E40AF", "use": "primary actions, the reveal screen, key highlight" },
      "bright": { "value": "#3B82F6", "use": "hover, gradient partner" },
      "tint":   { "value": "#EFF3FF", "use": "blue background chips (e.g. match %)" }
    },
    "border": {
      "default": { "value": "#ECECF0", "use": "card borders, dividers" }
    }
  },

  "font": {
    "family": {
      "display": { "value": "'Clash Display', sans-serif", "use": "headlines, names, eyebrows, buttons, section labels", "source": "Fontshare" },
      "body":    { "value": "'Inter', sans-serif", "use": "body text, UI, the 'why' paragraph", "source": "Google Fonts" }
    },
    "size": {
      "h1":    { "value": "34px" },
      "h2":    { "value": "24px" },
      "h3":    { "value": "18px" },
      "body":  { "value": "15px" },
      "small": { "value": "13px" },
      "label": { "value": "12px", "note": "floor for eyebrow/labels — never smaller" }
    },
    "weight": {
      "display": { "value": "600", "note": "headlines 500-600, never thin" },
      "body":    { "value": "400" },
      "medium":  { "value": "500", "note": "labels, buttons" }
    },
    "letterSpacing": {
      "tight":  { "value": "-0.015em", "use": "large display headlines" },
      "normal": { "value": "0" },
      "label":  { "value": "0.1em", "use": "uppercase eyebrows/labels" }
    },
    "lineHeight": {
      "tight": { "value": "1.1", "use": "headlines" },
      "body":  { "value": "1.6", "use": "paragraphs" }
    }
  },

  "space": {
    "1": { "value": "4px" },
    "2": { "value": "8px" },
    "3": { "value": "12px" },
    "4": { "value": "16px" },
    "6": { "value": "24px" },
    "8": { "value": "32px" },
    "12": { "value": "48px", "note": "section gap floor — keep it generous" }
  },

  "radius": {
    "sm":   { "value": "8px",  "use": "chips, small elements" },
    "md":   { "value": "12px", "use": "buttons" },
    "lg":   { "value": "16px", "use": "cards" },
    "xl":   { "value": "24px", "use": "device/page container" }
  },

  "shadow": {
    "card":    { "value": "0 4px 14px rgba(0,0,0,0.04)", "use": "resting cards" },
    "raised":  { "value": "0 12px 32px rgba(0,0,0,0.10)", "use": "lifted / hero cards" },
    "device":  { "value": "0 20px 48px rgba(0,0,0,0.14)", "use": "full container" }
  }
}
